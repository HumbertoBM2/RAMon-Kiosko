# .env.example — Copiar como .env y rellenar con tus valores reales

# ── AZURE TABLE STORAGE (para sesiones) ───────────────────────────
AZURE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=TU_CUENTA;AccountKey=TU_KEY;EndpointSuffix=core.windows.net
AZURE_TABLE_NAME=KioskoSessions

# ── AZURE IOT HUB (telemetría opcional) ───────────────────────────
AZURE_IOT_HUB_CONN_STR=HostName=TU_HUB.azure-devices.net;DeviceId=kiosko-ramon;SharedAccessKey=TU_KEY

# ── OLLAMA ─────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ── BASE DE DATOS LOCAL MySQL ──────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password_here
DB_NAME=kiosko_ramon
DB_ENABLED=true

# ── NODE.JS API LOCAL ──────────────────────────────────────────────
API_BASE_URL=http://localhost:3001
API_ENABLED=true

# ── CORREO (Gmail app password recomendado) ────────────────────────
EMAIL_SENDER=tucorreo@gmail.com
EMAIL_PASSWORD=tu_app_password_gmail
EMAIL_SMTP_SERVER=smtp.gmail.com
EMAIL_SMTP_PORT=587

# ── GOOGLE FORMS (para recolectar correo del turista) ─────────────
GOOGLE_FORMS_URL=https://forms.gle/TU_FORM_ID
